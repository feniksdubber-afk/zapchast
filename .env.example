# .env fayli — maxfiy ma'lumotlar (git'ga QO'SHILMASIN!)
# Bu faylni nusxa ko'chiring: cp .env.example .env

# Telegram botingiz tokeni (@BotFather'dan olingan)
BOT_TOKEN=your_bot_token_here

# Aros API sozlamalari (ixtiyoriy — standart qiymatlar mavjud)
# AROS_PAGE_SIZE=10
# HTTP_TIMEOUT=10.0
# HTTP_MAX_RETRIES=2

# FSM ma'lumotlarini (login, savat) qayerda saqlash.
# Railway'da Volume qo'shganda, uning "Mount Path" qiymatini shu yerga yozing.
# STORAGE_DIR=/app/data
